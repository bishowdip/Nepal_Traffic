# Nepal Traffic AI — Environment template
# Copy to .env and fill in real values locally. NEVER commit a real .env.
#   cp .env.example .env

DATABASE_URL=sqlite+aiosqlite:///./nepal_traffic.db
MOCK_MODE=true

# Camera sources (comma-separated RTSP URLs or video paths)
# CAMERA_SOURCES=rtsp://user:pass@192.168.1.10:554/stream1

# DoTM registry API key — leave blank for mock mode; set your real key locally.
DOTM_API_KEY=

# App secret — generate a random value in production, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Detection
CONFIDENCE_THRESHOLD=0.65

# OCR (easyocr | paddle | mock | empty=auto)
OCR_ENGINE=
OCR_GPU=true
OCR_PLATE_LANGS=en
OCR_ROUTE_LANGS=ne,en
OCR_MIN_CONF=0.30

# Checkpoint
CHECKPOINT_NAME=Thankot Checkpoint
CHECKPOINT_LOCATION=Thankot, Chandragiri Municipality, Kathmandu

# Logging
LOG_LEVEL=INFO

# CORS (comma-separated allowed origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080
