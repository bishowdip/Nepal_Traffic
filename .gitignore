# ── Secrets / environment ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# ── Test / tooling caches ─────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── Databases (regenerate via seeding) ────────────────────────────────────────
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite3

# ── Runtime artifacts ─────────────────────────────────────────────────────────
.pids/
logs/
*.log
reports/*.pdf
reports/*.csv

# ── ML weights & large media (distribute out-of-band, not in git) ─────────────
*.pt
*.onnx
*.engine
*.mp4
*.avi
*.mov

# ── Editor / OS ───────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
